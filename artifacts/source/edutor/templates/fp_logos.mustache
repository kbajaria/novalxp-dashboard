{{#uselogos}}
<div class="logo-section">
    <div class="container-fluid">
	    <div class="section-inner">
		    
		    {{#logossectiontitle}}
		    <h2 class="section-title text-center">{{{logossectiontitle}}}</h2>
		    {{/logossectiontitle}}
		    
		    {{#logossectionintro}}
		    <div class="section-intro">{{{logossectionintro}}}</div>
		    {{/logossectionintro}}
		    
		    <div class="logo-items d-flex justify-content-center align-items-center flex-wrap"> 
			    {{#logos}}
			    {{#haslogo}}
	            <div class="item">
		            <div class="item-inner">
			        {{#logourl}}    
	                <a href="{{{logourl}}}" target="_blank">
		            {{/logourl}}
		                {{#logoimage}}
		                <img loading="lazy" class="logo-img" src="{{{logoimage}}}" alt="image">
		                {{/logoimage}}
		            {{#logourl}}  
		            </a>
		            {{/logourl}}
		            </div><!--//item-inner-->
	            </div><!--//item-->
	            {{/haslogo}}
	            {{/logos}}
	        </div><!--//row-->	    
	    </div><!--//section-inner-->
    </div><!--//container-->
</div><!--//logo-section-->
{{/uselogos}}